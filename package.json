{
  "name": "noob-player",
  "version": "0.9.2",
  "description": "NooB Video Player - Fast lightweight media player",
  "main": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.noobz.noobplayer",
    "productName": "NooB Video Player",
    "files": [
      "**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "src/Assets/favicon.ico",
      "fileAssociations": [
        {
          "ext": [
            "mp4",
            "m4v",
            "webm",
            "ogv",
            "ogg",
            "mov",
            "qt",
            "3gp",
            "3g2",
            "avi",
            "wmv",
            "flv",
            "mpg",
            "mpeg",
            "mpe",
            "mkv"
          ],
          "name": "Video File",
          "description": "Video File",
          "icon": "src/Assets/favicon.png"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "src/Assets/favicon.icns",
      "category": "public.app-category.video",
      "fileAssociations": [
        {
          "ext": [
            "mp4",
            "m4v",
            "webm",
            "ogv",
            "ogg",
            "mov",
            "qt",
            "3gp",
            "3g2",
            "avi",
            "wmv",
            "flv",
            "mpg",
            "mpeg",
            "mpe",
            "mkv"
          ],
          "role": "Viewer"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons",
      "category": "AudioVideo",
      "fileAssociations": [
        {
          "ext": "mp4",
          "mimeType": "video/mp4"
        },
        {
          "ext": "m4v",
          "mimeType": "video/x-m4v"
        },
        {
          "ext": "webm",
          "mimeType": "video/webm"
        },
        {
          "ext": "ogv",
          "mimeType": "video/ogg"
        },
        {
          "ext": "ogg",
          "mimeType": "video/ogg"
        },
        {
          "ext": "mov",
          "mimeType": "video/quicktime"
        },
        {
          "ext": "qt",
          "mimeType": "video/quicktime"
        },
        {
          "ext": "3gp",
          "mimeType": "video/3gpp"
        },
        {
          "ext": "3g2",
          "mimeType": "video/3gpp2"
        },
        {
          "ext": "avi",
          "mimeType": "video/x-msvideo"
        },
        {
          "ext": "wmv",
          "mimeType": "video/x-ms-wmv"
        },
        {
          "ext": "flv",
          "mimeType": "video/x-flv"
        },
        {
          "ext": "mpg",
          "mimeType": "video/mpeg"
        },
        {
          "ext": "mpeg",
          "mimeType": "video/mpeg"
        },
        {
          "ext": "mpe",
          "mimeType": "video/mpeg"
        },
        {
          "ext": "mkv",
          "mimeType": "video/x-matroska"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}